---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const recipes = await getCollection("recipes");
---

<BaseLayout>
    <h1>Recipes</h1>

    <ul>
        {recipes.map((recipe) => (
                <li>
                    <a href={`/recipes/${recipe.slug}`}>
                        {recipe.data.title}
                    </a>
                </li>
        ))}
    </ul>
</BaseLayout>
