---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ViewCounter from "../../components/ViewCounter.astro";
import DiscussionPanel from "../../components/DiscussionPanel.astro";

export async function getStaticPaths() {
    const recipes = await getCollection("recipes");

    return recipes.map((recipe) => ({
        params: { slug: recipe.slug },
    }));
}

const { slug } = Astro.params;

const recipes = await getCollection("recipes");
const recipe = recipes.find((r) => r.slug === slug);

if (!recipe) {
    throw new Error("Recipe not found");
}

const { Content } = await recipe.render();
---

<BaseLayout
    title={recipe.data.title}
    description={recipe.data.description ?? "Recipe post from Adam Makes Coffee."}
    type="article"
    pubDate={recipe.data.date}
>
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Recipe",
        "name": recipe.data.title,
        "description": recipe.data.description ?? "",
        "datePublished": recipe.data.date.toISOString(),
        "author": { "@type": "Person", "name": "Adam", "url": "https://adammakes.coffee/whois" },
        "url": `https://adammakes.coffee/recipes/${slug}/`,
    })} />
    <h1>{recipe.data.title}</h1>
    <ViewCounter slug={`recipe:${slug}`} />
    <Content />
    <DiscussionPanel slug={`recipe:${slug}`} />
</BaseLayout>
