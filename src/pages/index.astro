---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const loadCollection = async (name: "recipes" | "blog" | "cats") => {
    try {
        return await getCollection(name);
    } catch {
        return [];
    }
};

const [recipes, blog, cats] = await Promise.all([
    loadCollection("recipes"),
    loadCollection("blog"),
    loadCollection("cats"),
]);

const updates = [...recipes, ...blog, ...cats]
    .map((entry) => ({
        slug: entry.slug,
        title: entry.data.title,
        date: entry.data.date,
        description: entry.data.description,
        collection: entry.collection,
    }))
    .sort((a, b) => b.date.getTime() - a.date.getTime());

const entityBasePath: Record<string, string> = {
    recipes: "/recipes",
    blog: "/software",
    cats: "/catPhotos",
};
---

<BaseLayout
    title="Home"
    description="Recent updates across recipes, blog posts, and cats."
>
    <canvas id="boids-canvas" aria-hidden="true"></canvas>
    <section class="portal-grid">
        <aside>
            <article class="panel retro-widget-panel">
                <h2>Toybox</h2>
                <div class="retro-widget">
                    <div class="terminal-counter" aria-live="polite">
                        <div class="terminal-titlebar">
                            <span class="terminal-dot"></span>
                            <span class="terminal-dot"></span>
                            <span class="terminal-dot"></span>
                            <span class="terminal-title">Visitor Counter</span>
                        </div>
                        <div class="terminal-screen">
                            <p class="terminal-line">
                                <span class="prompt">C:\id\you&gt;</span>
                                <span>visitor=</span><span id="page-counter-value">000001</span>
                            </p>
                            <p class="terminal-line dim">status: online</p>
                        </div>
                    </div>
                </div>
                <div class="retro-widget">
                    <div class="winamp-mini" aria-label="Now Playing module mockup">
                        <div class="winamp-titlebar">
                            <span>FtwAmp v0.1</span>
                            <div class="winamp-controls" aria-hidden="true">
                                <span>_</span>
                                <span>□</span>
                                <span>×</span>
                            </div>
                        </div>
                        <div class="winamp-body">
                            <div class="winamp-tier winamp-top">
                                <p class="winamp-track">Now Playing <span id="now-playing-name">&lt;Song Name&gt;</span></p>
                                <div class="winamp-controls-row">
                                    <div class="winamp-visualizer half" id="player-visualizer" aria-hidden="true">
                                        <span></span><span></span><span></span><span></span><span></span>
                                        <span></span><span></span><span></span><span></span><span></span>
                                    </div>
                                    <div class="winamp-buttons">
                                        <button id="player-prev" type="button" aria-label="Previous track">⏮</button>
                                        <button id="player-playpause" type="button" aria-label="Play">▶</button>
                                        <button id="player-next" type="button" aria-label="Next track">⏭</button>
                                    </div>
                                </div>
                            </div>

                            <div class="winamp-tier winamp-mid">
                                <div class="eq-shell" aria-hidden="true">
                                    <div class="eq-left">
                                        <span>ON</span>
                                        <span>AUTO</span>
                                    </div>
                                    <div class="eq-main">
                                        <div class="eq-sliders">
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                            <div class="eq-slider"><span class="eq-fill"></span><span class="eq-knob"></span></div>
                                        </div>
                                        <div class="eq-labels">
                                            <span>60</span>
                                            <span>170</span>
                                            <span>310</span>
                                            <span>600</span>
                                            <span>1k</span>
                                            <span>3k</span>
                                            <span>6k</span>
                                            <span>12k</span>
                                            <span>14k</span>
                                            <span>16k</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="winamp-tier winamp-bottom">
                                <p class="tracklist-title">Tracklist</p>
                                <ol class="tracklist" id="player-tracklist">
                                    <li class="active">
                                        <button
                                            data-url="https://soundcloud.com/gouranga/this-must-be-the-place-psychemagik-naive-edit"
                                            type="button"
                                        >
                                            This Must Be The Place (Psychemagik Naive Edit)
                                        </button>
                                    </li>
                                </ol>
                            </div>
                        </div>
                    </div>
                    <div class="legal-embed">
                        <div class="embed-shell">
                            <iframe
                                id="soundcloud-official-player"
                                title="Official track embed"
                                src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/gouranga/this-must-be-the-place-psychemagik-naive-edit&color=%2382AAFF&auto_play=false&hide_related=false&show_comments=false&show_user=true&show_reposts=false&show_teaser=true&visual=false"
                                loading="lazy"
                                allow="autoplay"
                            ></iframe>
                        </div>
                    </div>
                </div>
            </article>
        </aside>

        <section class="panel">
            <h2>Welcome</h2>
            <p>
                adammakes is my attempt to log my personal projects, weekend fun, and publish items that could be helpful for others. Not everything will be polished, and actually almost everything is a work in progress.
            </p>
            <p>
                But here it is, and I'm glad you stopped by!
            </p>

            <h2>Site Updates</h2>
            {updates.length === 0 ? (
                <p>No updates yet.</p>
            ) : (
                <ul class="updates-list">
                    {updates.map((update) => (
                        <li class="update-item">
                            <a href={`${entityBasePath[update.collection]}/${update.slug}`}>
                                {update.title}
                            </a>
                            <p class="update-meta">
                                {update.collection} · {update.date.toLocaleDateString()}
                            </p>
                            {update.description && (
                                <p class="update-desc">{update.description}</p>
                            )}
                        </li>
                    ))}
                </ul>
            )}
        </section>
    </section>

    <script is:inline>
        const key = "adammakes-page-counter";
        const startValue = 1;
        const current = Number(localStorage.getItem(key) || startValue);
        const next = Number.isFinite(current) ? current + 1 : startValue;
        localStorage.setItem(key, String(next));
        const target = document.getElementById("page-counter-value");
        if (target) {
            target.textContent = String(next).padStart(6, "0").slice(-6);
        }

        const soundcloudFrame = document.getElementById("soundcloud-official-player");
        const prevButton = document.getElementById("player-prev");
        const playPauseButton = document.getElementById("player-playpause");
        const nextButton = document.getElementById("player-next");
        const nowPlaying = document.getElementById("now-playing-name");
        const tracklist = document.getElementById("player-tracklist");
        const visualizer = document.getElementById("player-visualizer");

        if (soundcloudFrame && prevButton && playPauseButton && nextButton && nowPlaying && tracklist && visualizer) {
            const bars = Array.from(visualizer.querySelectorAll("span"));
            const trackButtons = Array.from(tracklist.querySelectorAll("button"));
            let visualizerTimer;
            let isPlaying = false;
            let widget;

            const playerOpts = {
                auto_play: false,
                show_comments: false,
                show_reposts: false,
                show_teaser: true,
                visual: false,
            };

            const loadScript = async () => new Promise((resolve, reject) => {
                if (window.SC && window.SC.Widget) {
                    resolve(true);
                    return;
                }
                const script = document.createElement("script");
                script.src = "https://w.soundcloud.com/player/api.js";
                script.async = true;
                script.onload = () => resolve(true);
                script.onerror = () => reject(new Error("Failed to load SoundCloud Widget API"));
                document.head.appendChild(script);
            });

            const startVisualizer = () => {
                clearInterval(visualizerTimer);
                visualizerTimer = setInterval(() => {
                    bars.forEach((bar) => {
                        const height = 3 + Math.floor(Math.random() * 12);
                        bar.style.height = `${height}px`;
                    });
                }, 90);
            };

            const stopVisualizer = () => {
                clearInterval(visualizerTimer);
                bars.forEach((bar) => {
                    bar.style.height = "3px";
                });
            };

            const updatePlayPauseUi = () => {
                playPauseButton.textContent = isPlaying ? "⏸" : "▶";
                playPauseButton.setAttribute("aria-label", isPlaying ? "Pause" : "Play");
                visualizer.classList.toggle("live", isPlaying);
                if (isPlaying) {
                    startVisualizer();
                } else {
                    stopVisualizer();
                }
            };

            const setActiveTrackByUrl = (trackUrl) => {
                trackButtons.forEach((button) => {
                    const isActive = button.dataset.url === trackUrl;
                    button.parentElement?.classList.toggle("active", isActive);
                });
            };

            const bindWidget = () => {
                widget.bind(window.SC.Widget.Events.READY, () => {
                    widget.getCurrentSound((sound) => {
                        if (sound?.title) nowPlaying.textContent = sound.title;
                        if (sound?.permalink_url) setActiveTrackByUrl(sound.permalink_url);
                    });
                    updatePlayPauseUi();
                });

                widget.bind(window.SC.Widget.Events.PLAY, () => {
                    isPlaying = true;
                    updatePlayPauseUi();
                    widget.getCurrentSound((sound) => {
                        if (sound?.title) nowPlaying.textContent = sound.title;
                        if (sound?.permalink_url) setActiveTrackByUrl(sound.permalink_url);
                    });
                });

                widget.bind(window.SC.Widget.Events.PAUSE, () => {
                    isPlaying = false;
                    updatePlayPauseUi();
                });

                widget.bind(window.SC.Widget.Events.FINISH, () => {
                    isPlaying = false;
                    updatePlayPauseUi();
                });
            };

            loadScript().then(() => {
                widget = window.SC.Widget(soundcloudFrame);
                bindWidget();
            }).catch(() => {
                nowPlaying.textContent = "SoundCloud embed unavailable";
            });

            prevButton.addEventListener("click", () => {
                if (!widget) return;
                widget.seekTo(0);
            });

            nextButton.addEventListener("click", () => {
                if (!widget) return;
                widget.getDuration((duration) => {
                    widget.getPosition((position) => {
                        const jumpTo = Math.min(duration, position + 15000);
                        widget.seekTo(jumpTo);
                    });
                });
            });

            playPauseButton.addEventListener("click", () => {
                if (!widget) return;
                widget.toggle();
            });

            trackButtons.forEach((button) => {
                button.addEventListener("click", () => {
                    if (!widget) return;
                    const url = button.dataset.url;
                    if (!url) return;
                    widget.load(url, { ...playerOpts, auto_play: true });
                });
            });

            stopVisualizer();
            updatePlayPauseUi();
        }
    </script>

    <script is:inline>
        (() => {
            if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

            const canvas = document.getElementById("boids-canvas");
            if (!canvas) return;
            // Move to body so it sits behind site-shell (z-index 0 vs 1)
            document.body.appendChild(canvas);
            const ctx = canvas.getContext("2d");

            const NUM_BOIDS = 35;
            const MAX_SPEED = 1.3;
            const MAX_FORCE = 0.03;
            const NEIGHBOR_RADIUS = 65;
            const SEP_RADIUS = 32;
            const REPULSOR_RADIUS = 50;
            const REPULSOR_STRENGTH = 0.25;
            const WANDER_STRENGTH = 0.012;
            const COLORS = ["#7fdbca", "#82AAFF", "#c5e478"];

            const NUM_STARS = 900;
            const STAR_COLORS = [
                "#ffffff", "#ffffff", "#ffffff", "#ffffff", // mostly white
                "#b8d4ff", // cool blue-white
                "#7fdbca", // cyan hint
                "#c5e478", // green hint
            ];
            const STAR_GLYPHS = ["✦", "✧", "✶", "✴", "⋆", "+", "×", "*"];

            const NUM_ASTEROIDS = 12;
            const ASTEROID_AVOID_RADIUS = 55;
            const ASTEROID_AVOID_STRENGTH = 1.4;

            let width, height, pageRect, stars = [];

            const resize = () => {
                width = canvas.width = window.innerWidth;
                height = canvas.height = window.innerHeight;
                const shell = document.querySelector(".site-shell");
                pageRect = shell ? shell.getBoundingClientRect() : null;
            };
            window.addEventListener("resize", resize);
            window.addEventListener("scroll", () => {
                const shell = document.querySelector(".site-shell");
                pageRect = shell ? shell.getBoundingClientRect() : null;
            }, { passive: true });
            resize();

            const initStars = () => {
                stars = Array.from({ length: NUM_STARS }, () => {
                    const r = 0.1 + Math.random() * 0.38;
                    return {
                        x: Math.random() * width,
                        y: Math.random() * height,
                        fontSize: Math.max(3, Math.round(r * 16)),
                        alpha: 0.2 + Math.random() * 0.65,
                        color: STAR_COLORS[Math.floor(Math.random() * STAR_COLORS.length)],
                        glyph: STAR_GLYPHS[Math.floor(Math.random() * STAR_GLYPHS.length)],
                    };
                });
                // Sort by fontSize to minimise ctx.font reassignments
                stars.sort((a, b) => a.fontSize - b.fontSize);
            };
            initStars();

            const boids = Array.from({ length: NUM_BOIDS }, () => ({
                x: Math.random() * width,
                y: Math.random() * height,
                vx: (Math.random() - 0.5) * MAX_SPEED * 2,
                vy: (Math.random() - 0.5) * MAX_SPEED * 2,
                color: COLORS[Math.floor(Math.random() * COLORS.length)],
                wanderAngle: Math.random() * Math.PI * 2,
            }));

            const makeVerts = (r, n) => Array.from({ length: n }, (_, i) => {
                const a = (i / n) * Math.PI * 2;
                const jitter = r * (0.65 + Math.random() * 0.5);
                return [Math.cos(a) * jitter, Math.sin(a) * jitter];
            });

            const asteroids = Array.from({ length: NUM_ASTEROIDS }, () => {
                const r = 9 + Math.random() * 11;
                return {
                    x: Math.random() * width,
                    y: Math.random() * height,
                    vx: (Math.random() - 0.5) * 0.55,
                    vy: (Math.random() - 0.5) * 0.55,
                    spin: (Math.random() - 0.5) * 0.018,
                    angle: Math.random() * Math.PI * 2,
                    radius: r,
                    verts: makeVerts(r, 7 + Math.floor(Math.random() * 3)),
                };
            });

            const clamp = (vx, vy, max) => {
                const spd = Math.hypot(vx, vy);
                return spd > max ? [vx / spd * max, vy / spd * max] : [vx, vy];
            };

            const steerToward = (boid, tx, ty) => {
                const mag = Math.hypot(tx, ty);
                if (mag === 0) return [0, 0];
                return clamp(tx / mag * MAX_SPEED - boid.vx, ty / mag * MAX_SPEED - boid.vy, MAX_FORCE);
            };

            // Returns the force vector pushing boid away from the page rect
            const INSET = 120; // boids can travel this far inside the rect before being pushed
            const pageRepulsor = (boid) => {
                if (!pageRect) return [0, 0];
                // Shrink the rect inward so boids can pass well under the content
                const r = {
                    left:   pageRect.left   + INSET,
                    right:  pageRect.right  - INSET,
                    top:    pageRect.top    + INSET,
                    bottom: pageRect.bottom - INSET,
                };
                if (r.right < r.left || r.bottom < r.top) return [0, 0];
                // Nearest point on the shrunken rect to the boid
                const nx = Math.max(r.left, Math.min(boid.x, r.right));
                const ny = Math.max(r.top,  Math.min(boid.y, r.bottom));
                const dx = boid.x - nx;
                const dy = boid.y - ny;
                const d = Math.hypot(dx, dy);
                if (d === 0 || d > REPULSOR_RADIUS) return [0, 0];
                const strength = REPULSOR_STRENGTH * (1 - d / REPULSOR_RADIUS);
                return [dx / d * strength, dy / d * strength];
            };

            const tick = (boid) => {
                let sepX = 0, sepY = 0, sepN = 0;
                let aliVx = 0, aliVy = 0, aliN = 0;
                let cohX = 0, cohY = 0, cohN = 0;

                for (const other of boids) {
                    if (other === boid) continue;
                    const dx = boid.x - other.x;
                    const dy = boid.y - other.y;
                    const d = Math.hypot(dx, dy);

                    if (d < SEP_RADIUS && d > 0) {
                        sepX += dx / d;
                        sepY += dy / d;
                        sepN++;
                    }
                    if (d < NEIGHBOR_RADIUS) {
                        aliVx += other.vx;
                        aliVy += other.vy;
                        aliN++;
                        cohX += other.x;
                        cohY += other.y;
                        cohN++;
                    }
                }

                let fx = 0, fy = 0;

                if (sepN > 0) {
                    const [sx, sy] = steerToward(boid, sepX / sepN, sepY / sepN);
                    fx += sx * 1.6;
                    fy += sy * 1.6;
                }
                if (aliN > 0) {
                    const [ax, ay] = steerToward(boid, aliVx / aliN, aliVy / aliN);
                    fx += ax;
                    fy += ay;
                }
                if (cohN > 0) {
                    const [cx, cy] = steerToward(boid, cohX / cohN - boid.x, cohY / cohN - boid.y);
                    fx += cx * 0.2;
                    fy += cy * 0.2;
                }

                // Page repulsor
                const [rx, ry] = pageRepulsor(boid);
                fx += rx;
                fy += ry;

                // Asteroid avoidance
                for (const a of asteroids) {
                    const dx = boid.x - a.x;
                    const dy = boid.y - a.y;
                    const d = Math.hypot(dx, dy);
                    if (d < ASTEROID_AVOID_RADIUS && d > 0) {
                        const strength = ASTEROID_AVOID_STRENGTH * (1 - d / ASTEROID_AVOID_RADIUS);
                        fx += (dx / d) * strength;
                        fy += (dy / d) * strength;
                    }
                }

                // Wander: drift the boid's personal wander angle slightly each tick
                boid.wanderAngle += (Math.random() - 0.5) * 0.4;
                fx += Math.cos(boid.wanderAngle) * WANDER_STRENGTH;
                fy += Math.sin(boid.wanderAngle) * WANDER_STRENGTH;

                boid.vx += fx;
                boid.vy += fy;
                [boid.vx, boid.vy] = clamp(boid.vx, boid.vy, MAX_SPEED);

                boid.x += boid.vx;
                boid.y += boid.vy;

                if (boid.x < -12) boid.x = width + 12;
                if (boid.x > width + 12) boid.x = -12;
                if (boid.y < -12) boid.y = height + 12;
                if (boid.y > height + 12) boid.y = -12;
            };

            const drawBoid = (boid) => {
                const angle = Math.atan2(boid.vy, boid.vx);
                const s = 7;

                ctx.save();
                ctx.translate(boid.x, boid.y);
                ctx.rotate(angle - Math.PI / 2);

                ctx.beginPath();
                ctx.moveTo(-s * 0.55, -s * 0.45);
                ctx.lineTo(0, s * 0.55);
                ctx.lineTo(s * 0.55, -s * 0.45);
                ctx.lineJoin = "round";

                // Glow pass
                ctx.strokeStyle = boid.color;
                ctx.lineWidth = 3.5;
                ctx.globalAlpha = 0.35;
                ctx.shadowColor = boid.color;
                ctx.shadowBlur = 14;
                ctx.stroke();

                // Crisp top pass
                ctx.lineWidth = 1.4;
                ctx.globalAlpha = 0.9;
                ctx.shadowBlur = 0;
                ctx.stroke();

                ctx.restore();
            };

            const tickAsteroid = (a) => {
                a.angle += a.spin;
                a.x += a.vx;
                a.y += a.vy;
                if (a.x < -20) a.x = width + 20;
                if (a.x > width + 20) a.x = -20;
                if (a.y < -20) a.y = height + 20;
                if (a.y > height + 20) a.y = -20;
            };

            const drawAsteroid = (a) => {
                ctx.save();
                ctx.translate(a.x, a.y);
                ctx.rotate(a.angle);

                ctx.beginPath();
                a.verts.forEach(([x, y], i) => {
                    if (i === 0) ctx.moveTo(x, y);
                    else ctx.lineTo(x, y);
                });
                ctx.closePath();

                // Glow pass
                ctx.strokeStyle = "#7a8fa8";
                ctx.lineWidth = 3;
                ctx.globalAlpha = 0.25;
                ctx.shadowColor = "#7a8fa8";
                ctx.shadowBlur = 10;
                ctx.stroke();

                // Crisp pass
                ctx.lineWidth = 1.2;
                ctx.globalAlpha = 0.7;
                ctx.shadowBlur = 0;
                ctx.stroke();

                ctx.restore();
            };

            const drawStars = () => {
                ctx.textAlign = "center";
                ctx.textBaseline = "middle";
                ctx.shadowBlur = 0;
                let lastSize = -1;
                for (const s of stars) {
                    if (s.fontSize !== lastSize) {
                        ctx.font = `${s.fontSize}px sans-serif`;
                        lastSize = s.fontSize;
                    }
                    ctx.globalAlpha = s.alpha;
                    ctx.fillStyle = s.color;
                    ctx.fillText(s.glyph, s.x, s.y);
                }
                ctx.globalAlpha = 1;
                ctx.textAlign = "start";
                ctx.textBaseline = "alphabetic";
            };

            const frame = () => {
                ctx.clearRect(0, 0, width, height);
                drawStars();
                for (const a of asteroids) {
                    tickAsteroid(a);
                    drawAsteroid(a);
                }
                for (const boid of boids) {
                    tick(boid);
                    drawBoid(boid);
                }
                requestAnimationFrame(frame);
            };

            requestAnimationFrame(frame);
        })();
    </script>
</BaseLayout>
