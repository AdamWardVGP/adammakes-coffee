---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="whois"
    description="Who runs this place?"
>
    <div class="whois-shell">

        <section class="panel">
            <div class="terminal-counter">
                <div class="terminal-titlebar">
                    <span class="terminal-dot"></span>
                    <span class="terminal-dot"></span>
                    <span class="terminal-dot"></span>
                    <span class="terminal-title">terminal - whois adam</span>
                </div>
                <div class="terminal-screen">

                    <figure class="crt-frame" aria-label="Portrait of Adam">
                        <div class="ascii-top" aria-hidden="true">
                            <span>╔</span><span class="ascii-hfill"></span><span>╗</span>
                        </div>
                        <div class="ascii-mid">
                            <span class="ascii-vfill" aria-hidden="true"></span>
                            <div class="crt-photo-wrap">
                                <img src="/adam_headshot.png" class="crt-photo" alt="Adam" />
                            </div>
                            <span class="ascii-vfill" aria-hidden="true"></span>
                        </div>
                        <div class="ascii-bot" aria-hidden="true">
                            <span>╚</span><span class="ascii-hfill"></span><span>╝</span>
                        </div>
                    </figure>

                    <p class="terminal-line" data-tw="type" data-tw-speed="22"><span class="prompt">coffee$</span> whois adam</p>
                    <p class="terminal-line dim" id="tw-query-line" data-tw="type" data-tw-speed="62" data-tw-delay="200">querying registry...</p>
                    <p data-tw="show" data-tw-delay="420"></p>
                    <p data-tw="show"></p>
                    <p class="terminal-line" data-tw="type" data-tw-speed="28"><span class="prompt"></span> Handle: <span class="tval cyan">Adam</span></p>
                    <p class="terminal-line" data-tw="type" data-tw-speed="22" data-tw-delay="180"><span class="prompt"></span> Role: <span class="tval green">gamer / cat dad / software engineer</span></p>
                    <p class="terminal-line" id="tw-status-line" data-tw="type" data-tw-speed="22" data-tw-delay="180"><span class="prompt"></span> Status: <span class="tval access-denied tw-badge" style="display:none">USER ACCESS UNAUTHORIZED</span></p>
                    <p class="terminal-line dim" data-tw="show" data-tw-delay="260">---</p>
                    <p class="terminal-line dim" data-tw="type" data-tw-speed="18" data-tw-delay="60">Record last updated: just today and never again.</p>
                    <p class="terminal-line dim" data-tw="show" data-tw-delay="100">---</p>

                    <p class="terminal-line" data-tw="type" data-tw-speed="24" data-tw-delay="320"><span class="prompt"></span> <span class="tval cyan">// about</span></p>
                    <p class="terminal-output" data-tw="type" data-tw-speed="7" data-tw-delay="140">I'm Adam. I make coffee, play games, write software, cook food, and share space with my partner and two incredible cats who can jump through hoops but still can't understand that I don't want them on my keyboard.</p>
                    <p class="terminal-output" data-tw="type" data-tw-speed="7" data-tw-delay="200">This site is <em>not</em> a portfolio. It's not optimized for LinkedIn. It has no cookie consent modal, no newsletter popup, no "We value your privacy" banner that values nothing. It's just a website.</p>
                    <p class="terminal-output" data-tw="type" data-tw-speed="7" data-tw-delay="200">The web peaked somewhere around 2005&ndash;2009. We had weird personal sites, RSS feeds, web rings and forums where people were chill, creativity was rampant, and we found each other through happenstance not algorithms. Then everything turned into a walled garden with ads, a subscription tier, an app (sorry my fault), a "platform", and it just wasn't as fun as it used to be.</p>
                    <p class="terminal-output" data-tw="type" data-tw-speed="7" data-tw-delay="200">Here I am, back where I started with HTML, CSS and some markdown. RIP flash.</p>

                    <p class="terminal-line dim" data-tw="show" data-tw-delay="320">---</p>

                    <p class="terminal-line" data-tw="type" data-tw-speed="24" data-tw-delay="220"><span class="prompt"></span> <span class="tval cyan">// elsewhere</span></p>
                    <p class="terminal-output" data-tw="type" data-tw-speed="10" data-tw-delay="140">I'm on the internet in a few places. Reluctantly.</p>
                    <p class="terminal-line terminal-link-line" data-tw="type" data-tw-speed="18" data-tw-delay="100"><span class="prompt"></span> <a href="https://github.com/AdamWardVGP" target="_blank" rel="noopener noreferrer">GitHub</a> - where my actual code lives</p>
                    <p class="terminal-line terminal-link-line" data-tw="type" data-tw-speed="18" data-tw-delay="100"><span class="prompt"></span> <a href="https://www.linkedin.com/in/wardadam/" target="_blank" rel="noopener noreferrer">LinkedIn</a> - where I pretend to be a professional human</p>

                    <p class="terminal-line dim" data-tw="show" data-tw-delay="320">---</p>

                    <p class="terminal-line terminal-prompt-line" data-tw="show" data-tw-delay="420">
                        <span class="prompt">adam@coffee:~$</span>
                        <span class="blink-cursor" aria-hidden="true">&#x2588;</span>
                    </p>

                </div>
            </div>
        </section>

    </div>
</BaseLayout>

<style>
.whois-shell {
    display: grid;
    gap: 1rem;
}

/* ══ ASCII-framed CRT portrait ══ */

.crt-frame {
    display: block;
    box-sizing: border-box;
    float: right;
    margin: 0 0 0.75rem 1rem;
    width: 160px;
    max-width: 160px;
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    line-height: 1;
    color: var(--accent-cyan);
    text-shadow: 0 0 7px rgba(127, 219, 202, 0.55);
    position: relative;
    z-index: 1;
    padding: 0;
    border: none;
    background: none;
}

.ascii-top,
.ascii-bot {
    display: flex;
    align-items: center;
    white-space: nowrap;
}

.ascii-hfill {
    flex: 1;
    overflow: hidden;
    height: 1em;
}

.ascii-hfill::before {
    content: "════════════════════════════════════════════════════════════════";
    display: block;
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    line-height: 1;
    color: var(--accent-cyan);
}

.ascii-mid {
    display: flex;
    align-items: stretch;
}

.ascii-vfill {
    flex-shrink: 0;
    overflow: hidden;
    height: 195px;
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    line-height: 1;
    color: var(--accent-cyan);
    text-shadow: 0 0 7px rgba(127, 219, 202, 0.55);
    white-space: pre;
}

.ascii-vfill::before {
    content: "║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║\A║";
    display: block;
}

.crt-photo-wrap {
    flex: 1;
    overflow: hidden;
    background: #000;
    box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.65);
    position: relative;
}

.crt-photo {
    display: block;
    width: 100%;
    height: 195px;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(1) sepia(1) hue-rotate(85deg) contrast(1.2) brightness(0.7);
    animation: crt-flicker 10s infinite;
}


.crt-photo-wrap::before {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
        to bottom,
        transparent 0,
        transparent 2px,
        rgba(0, 0, 0, 0.3) 2px,
        rgba(0, 0, 0, 0.3) 4px
    );
    pointer-events: none;
    z-index: 2;
}

.crt-photo-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse at 50% 35%, rgba(100, 219, 127, 0.12) 0%, transparent 65%),
        linear-gradient(180deg, rgba(100, 219, 127, 0.05) 0%, rgba(0, 0, 0, 0.15) 100%);
    pointer-events: none;
    z-index: 3;
    mix-blend-mode: screen;
}

@keyframes crt-flicker {
    0%, 86%, 88.5%, 100% {
        filter: grayscale(1) sepia(1) hue-rotate(85deg) contrast(1.2) brightness(0.7);
    }
    87% {
        filter: grayscale(1) sepia(1) hue-rotate(85deg) contrast(1.6) brightness(0.45);
    }
    88% {
        filter: grayscale(1) sepia(1) hue-rotate(85deg) contrast(1.25) brightness(0.65) blur(1px);
    }
}

/* ══ terminal text ══ */

.tval { font-family: "Courier New", monospace; }
.tval.cyan   { color: var(--accent-cyan); }
.tval.green  { color: var(--accent-green); }
.tval.yellow { color: var(--accent-yellow); }
.tval.access-denied {
    color: #000;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.1em 0.5em;
    border-radius: 2px;
    animation: access-denied-flash 0.8s step-start infinite;
}
@keyframes access-denied-flash {
    0%, 100% { background: var(--accent-purple); box-shadow: 0 0 8px 2px #c792ea, 0 0 18px 4px #c792ea88; }
    50% { background: #6a3d8f; box-shadow: 0 0 4px 1px #6a3d8f; }
}

.terminal-output {
    position: relative;
    z-index: 1;
    margin: 0.4rem 0 0;
    padding-left: 1.1rem;
    font-family: "Courier New", monospace;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.55;
}

.terminal-output + .terminal-output {
    margin-top: 0.5rem;
}

.terminal-output em {
    color: var(--accent-yellow);
    font-style: normal;
    font-weight: 600;
}

.terminal-link-line {
    margin-top: 0.4rem !important;
}

.terminal-link-line a {
    color: var(--accent-cyan);
    font-family: "Courier New", monospace;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
}

.terminal-link-line a:hover {
    color: var(--text-bright);
}

/* ══ typewriter — hide until revealed by JS ══ */

[data-tw] { display: none; }

/* ══ fixed-height terminal that fills up ══ */

.terminal-screen {
    height: 660px;
    overflow-y: auto;
    scroll-behavior: smooth;
}

/* ══ blinking cursor ══ */

.terminal-prompt-line {
    clear: both;
    margin-top: 0.85rem !important;
}


/* ══ stack ══ */

.stack-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.5rem;
}

.stack-col h3 { margin-top: 0; }

.stack-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.4rem;
}

.stack-list li {
    font-size: 0.88rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.38rem 0.6rem;
    background: var(--bg-tertiary);
}

.stack-list.nope li { color: var(--text-secondary); }
.stack-list.nope code { color: var(--accent-red); }

/* ══ timeline ══ */

.timeline {
    margin-top: 0.5rem;
    border-left: 2px solid var(--border);
    padding-left: 1.2rem;
}

.tl-entry {
    position: relative;
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 0.75rem;
    padding: 0.55rem 0;
}

.tl-entry::before {
    content: "";
    position: absolute;
    left: -1.38rem;
    top: 1rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-cyan);
    border: 2px solid var(--bg-primary);
}

.tl-year {
    font-family: "Courier New", monospace;
    font-size: 0.72rem;
    color: var(--accent-yellow);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-top: 0.18rem;
    text-align: right;
}

.tl-body strong { color: var(--text-bright); font-size: 0.95rem; }

.tl-body p {
    margin: 0.2rem 0 0;
    font-size: 0.85rem;
    color: var(--text-secondary);
}

/* ══ responsive ══ */

@media (prefers-reduced-motion: reduce) {
    [data-tw] { display: revert; }
}

@media (max-width: 600px) {
    .crt-frame {
        float: none;
        margin: 0 0 0.85rem 0;
        width: 100%;
    }

    .crt-photo {
        height: 220px;
        object-position: center top;
    }

    .ascii-vfill {
        height: 220px;
    }

    .stack-grid { grid-template-columns: 1fr; }
}
</style>

<script is:inline>
(() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const sleep = ms => new Promise(r => setTimeout(r, ms));
    const screen = document.querySelector('.terminal-screen');

    // ── Typing cursor ───────────────────────────────────────────────────────
    const typeCursor = document.createElement('span');
    typeCursor.className = 'blink-cursor';
    typeCursor.setAttribute('aria-hidden', 'true');
    typeCursor.textContent = '█';

    // ── Spinning progress indicator ─────────────────────────────────────────
    async function runSpinner(parentEl) {
        const frames = ['\\', '|', '/', '-'];
        const spinEl = document.createElement('span');
        spinEl.style.cssText = 'font-family:"Courier New",monospace; color:var(--accent-cyan); margin-left:0.45em;';
        parentEl.insertBefore(spinEl, typeCursor);

        await sleep(180);
        for (let i = 0; i < 12; i++) {
            spinEl.textContent = frames[i % frames.length];
            await sleep(140);
        }
        spinEl.remove();
    }

    // ── Typewriter ──────────────────────────────────────────────────────────
    async function typeElement(el, charMs) {
        const nodes = [];
        const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
                return node.parentElement.closest('.tw-badge')
                    ? NodeFilter.FILTER_REJECT
                    : NodeFilter.FILTER_ACCEPT;
            }
        });
        let node;
        while ((node = walker.nextNode())) {
            nodes.push({ node, text: node.textContent });
            node.textContent = '';
        }

        el.style.display = 'block';
        el.appendChild(typeCursor);

        for (const { node, text } of nodes) {
            for (const ch of text) {
                node.textContent += ch;
                const jitter = (Math.random() - 0.5) * charMs * 0.42;
                await sleep(Math.max(4, charMs + jitter));
            }
        }
    }

    // ── Sequence ────────────────────────────────────────────────────────────
    async function run() {
        const els = document.querySelectorAll('[data-tw]');

        await sleep(550);

        for (const el of els) {
            const delay = parseInt(el.dataset.twDelay ?? '0', 10);
            const speed = parseInt(el.dataset.twSpeed ?? '28', 10);
            const mode  = el.dataset.tw;

            if (delay > 0) await sleep(delay);

            if (mode === 'type') {
                await typeElement(el, speed);
                // Special post-type effect for the querying line
                if (el.id === 'tw-query-line') await runSpinner(el);
                if (el.id === 'tw-status-line') {
                    await runSpinner(el);
                    const badge = el.querySelector('.tw-badge');
                    if (badge) {
                        badge.style.display = 'inline';
                        await sleep(600);
                    }
                }
            } else {
                el.style.display = 'block';
            }

            if (screen) screen.scrollTop = screen.scrollHeight;
        }

        typeCursor.remove();
        audio.done();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
    } else {
        run();
    }
})();
</script>