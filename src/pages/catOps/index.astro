                        <div class="polaroid-wrap">
                            <div class="paperclip" aria-hidden="true"></div>
                            <div class="polaroid" style="--rot: 1.4deg">
                                <img src="/cats/izzy_the_noodle.jpg" alt="Izzy" />
                                <div class="polaroid-caption typewriter">Agent Noodle</div>
                            </div>
                        </div>
                        <div class="passport-fields typewriter">
                            <div class="field-row">
                                <span class="field-label">designation</span>
                                <span class="field-dots"></span>
                                <span class="field-value">Izzy</span>
                            </div>
                            <div class="field-row">
                                <span class="field-label">codename</span>
                                <span class="field-dots"></span>
                                <span class="field-value">Agent Noodle</span>
                            </div>
                            <div class="field-row">
                                <span class="field-label">species</span>
                                <span class="field-dots"></span>
                                <span class="field-value">cat (disputed)</span>
                            </div>
                            <div class="field-row">
                                <span class="field-label">status</span>
                                <span class="field-dots"></span>
                                <span class="field-value field-active">ACTIVE</span>
                            </div>
                            <div class="field-row">
                                <span class="field-label">clearance</span>
                                <span class="field-dots"></span>
                                <span class="field-value">cardboard box: approved</span>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>
                <div class="header-rule"></div>

            </div>
        </div>

        <!-- ══ MISSION REPORTS ══ -->
        <div class="missions-section">
            <div class="missions-tab-row">
                <div class="section-tab typewriter">mission reports</div>
                {missions.map(({ entry }, i) => (
                    <button class={`report-tab typewriter${i === 0 ? ' active' : ''}`} data-idx={String(i)}>
                        {entry.data.title}
                    </button>
                ))}
            </div>

            <div class="missions-body">
                {missions.length === 0 ? (
                    <p class="typewriter mission-empty">No field reports on file. Surveillance ongoing.</p>
                ) : (
                    missions.map(({ entry, Content }, i) => (
                        <div class={`mission-panel${i === 0 ? '' : ' hidden'}`} data-panel={String(i)}>
                            <div class="mission-header">
                                <span class="stamp stamp-red stamp-lg">{entry.data.title}</span>
                                <span class="mission-header-date typewriter">{entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }).toUpperCase()}</span>
                            </div>

                            <div class="mission-notes">
                                {entry.data.description && (
                                    <>
                                        <p class="mission-text typewriter mission-label">Summary:</p>
                                        <p class="mission-text typewriter">{entry.data.description}</p>
                                        <p class="mission-text typewriter">&nbsp;</p>
                                    </>
                                )}
                                <p class="mission-text typewriter mission-label">Report:</p>
                                <div class="mission-body typewriter"><Content /></div>
                            </div>

                            {entry.data.photos && entry.data.photos.length > 0 && (
                                <div class="mission-photos">
                                    {entry.data.photos.slice(0, 8).map((photo, j) => (
                                        <div class="polaroid mission-polaroid"
                                             style={`--rot: ${[-3.2,2.8,-1.5,4.1,-2.7,1.9,-3.8,2.3][j%8]}deg; --tx: ${[0,5,-6,2,-3,6,-4,1][j%8]}px; --ty: ${[4,-2,5,-3,2,-5,1,-2][j%8]}px`}>
                                            {j % 4 === 0 && <div class="mount tape tape--center"></div>}
                                            {j % 4 === 1 && <div class="mount pushpin pushpin--red"></div>}
                                            {j % 4 === 2 && <div class="mount tape tape--angled"></div>}
                                            {j % 4 === 3 && <div class="mount pushpin pushpin--blue"></div>}
                                            <img src={photo.src} alt={photo.caption ?? `photo ${j + 1}`} />
                                            {photo.caption && <div class="polaroid-caption typewriter">{photo.caption}</div>}
                                        </div>
                                    ))}
                                </div>
                            )}
                        </div>
                    ))
                )}
            </div>
        </div>

    </div>
</BaseLayout>

<style>
/*
@font-face {
    font-family: "Lemon Tuesday";
    src: url("/fonts/lemon_tuesday.otf") format("opentype");
    font-display: swap;
}
*/

@font-face {
    font-family: "Lacquer Regular";
    src: url("/fonts/lacquer_regular.ttf") format("opentype");
    font-display: swap;
}

.dossier-shell {
    display: flex;
    flex-direction: column;
    gap: 0;
    font-family: "Courier New", monospace;
    padding: 0.5rem 0 3rem;
    overflow: visible;
}

.typewriter {
    font-family: "Courier New", monospace;
    color: #1c1008;
}

/* ══ paper texture ══ */

.dossier-paper-bg {
    background: #f0e6c6;
    background-image: repeating-linear-gradient(
        transparent 0px, transparent 23px,
        rgba(139, 90, 43, 0.07) 23px, rgba(139, 90, 43, 0.07) 24px
    );
}

/* ══ header ══ */

.dossier-header {
    background: #f0e6c6;
    background-image: repeating-linear-gradient(
        transparent 0px, transparent 23px,
        rgba(139, 90, 43, 0.07) 23px, rgba(139, 90, 43, 0.07) 24px
    );
    border: 1px solid #c9b882;
    border-radius: 6px;
    padding: 1.1rem 1.25rem 0.85rem;
    transform: rotate(-0.7deg);
    transform-origin: top center;
    box-shadow: 3px 8px 24px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(201, 184, 130, 0.2);
    position: relative;
    z-index: 1;
    margin-bottom: -35rem;
}

.header-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
}

.header-ref {
    font-size: 0.68rem;
    color: #5a3e1a;
    opacity: 0.65;
}

.dossier-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1c1008;
    margin: 0 0 0.2rem;
    text-transform: lowercase;
    letter-spacing: 0.04em;
}

.dossier-subtitle {
    font-size: 0.7rem;
    color: #5a3e1a;
    margin: 0;
    opacity: 0.7;
}

.header-rule {
    height: 1px;
    background: linear-gradient(90deg, rgba(28,16,8,0.3) 0%, transparent 100%);
    margin-top: 0.85rem;
}

/* ══ stamp ══ */

.stamp {
    display: inline-block;
    font-family: "Courier New", monospace;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #8b1a1a;
    border: 2px solid #8b1a1a;
    padding: 0.12em 0.5em;
    transform: rotate(-2.5deg);
    opacity: 0.8;
    flex-shrink: 0;
}

.stamp-sm {
    font-size: 0.58rem;
    border-width: 1.5px;
    transform: rotate(-1.2deg);
}

.stamp-lg {
    font-size: 1rem;
    border-width: 2.5px;
    transform: rotate(-1.2deg);
    padding: 0.15em 0.6em;
}

/* ══ section tab ══ */

.section-tab {
    display: inline-block;
    background: #c4a24a;
    color: #1c1008;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.22em 0.85em;
    border-radius: 4px 4px 0 0;
    border: 1px solid #a88630;
    border-bottom: none;
    margin-bottom: -1px;
    position: relative;
    z-index: 1;
}

/* ══ passports ══ */

.passports-section {
    margin-top: 0;
    transform: rotate(1.0deg);
    transform-origin: top center;
    position: relative;
    z-index: 2;
    margin-bottom: -2.5rem;
}

.passports-paper {
    background: #f0e6c6;
    background-image: repeating-linear-gradient(
        transparent 0px, transparent 23px,
        rgba(139, 90, 43, 0.07) 23px, rgba(139, 90, 43, 0.07) 24px
    );
    border: 1px solid #c9b882;
    border-radius: 0 6px 6px 6px;
    padding: 1.6rem 1.5rem 1.4rem;
    box-shadow: 3px 8px 24px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(201, 184, 130, 0.2);
}

.passports-grid {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    flex-wrap: wrap;
}

.passport {
    flex: 1;
    min-width: 200px;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
}

.passport-divider {
    width: 1px;
    align-self: stretch;
    flex-shrink: 0;
    background: repeating-linear-gradient(
        to bottom, rgba(28,16,8,0.2) 0px, rgba(28,16,8,0.2) 4px,
        transparent 4px, transparent 8px
    );
}

/* ══ polaroid ══ */

.polaroid-wrap {
    position: relative;
    display: inline-block;
    flex-shrink: 0;
    margin-top: 22px;
}

.polaroid {
    background: #fff;
    padding: 6px 6px 36px;
    box-shadow: 2px 3px 10px rgba(0,0,0,0.2), 0 0 0 1px rgba(0,0,0,0.05);
    display: block;
    transform: rotate(var(--rot, 0deg));
}

.polaroid img {
    display: block;
    width: 130px;
    height: 145px;
    object-fit: cover;
    object-position: center top;
}

/* vignette + warm light-leak overlay */
.polaroid::before {
    content: "";
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 36px;
    pointer-events: none;
    z-index: 2;
}

.polaroid-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.58rem;
    color: #3a2208;
    text-align: center;
    padding: 0 4px;
}

/* ══ paperclip ══ */

.paperclip {
    position: absolute;
    top: -22px;
    left: 18px;
    width: 15px;
    height: 46px;
    border: 3.5px solid #b8b8b8;
    border-radius: 8px 8px 0 0;
    border-bottom: none;
    z-index: 2;
    box-shadow: 1px 1px 0 rgba(255,255,255,0.7);
}

.paperclip::after {
    content: "";
    position: absolute;
    top: 8px;
    left: 2.5px;
    width: 6px;
    height: 28px;
    border: 3px solid #b8b8b8;
    border-radius: 5px 5px 0 0;
    border-bottom: none;
}

/* ══ passport fields ══ */

.passport-fields {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.5rem;
}

.field-row {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    font-size: 0.7rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid rgba(28, 16, 8, 0.1);
}

.field-label {
    flex-shrink: 0;
    color: #5a3e1a;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.7;
    min-width: 5rem;
}

.field-dots {
    flex: 1;
    border-bottom: 1px dotted rgba(28, 16, 8, 0.2);
    margin-bottom: 2px;
    min-width: 0.5rem;
}

.field-value {
    flex-shrink: 0;
    color: #1c1008;
    font-weight: 600;
}

.field-active {
    color: #1a6b1a;
    letter-spacing: 0.06em;
}

/* ══ missions ══ */

.missions-section {
    margin-top: -18rem;
    position: relative;
    z-index: 3;
}

.missions-tab-row {
    display: flex;
    align-items: flex-end;
    gap: 2px;
}

.report-tab {
    font-family: "Courier New", monospace;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #5a3e1a;
    background: #d4b86a;
    border: 1px solid #a88630;
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    padding: 0.22em 0.85em;
    cursor: pointer;
    position: relative;
    z-index: 1;
    margin-bottom: -1px;
    opacity: 0.75;
}

.report-tab.active {
    background: #f0e6c6;
    border-color: #c9b882;
    color: #1c1008;
    opacity: 1;
    z-index: 2;
}

.missions-body {
    background: #f0e6c6;
    background-image: repeating-linear-gradient(
        transparent 0px, transparent 23px,
        rgba(139, 90, 43, 0.07) 23px, rgba(139, 90, 43, 0.07) 24px
    );
    border: 1px solid #c9b882;
    border-radius: 0 6px 6px 6px;
    padding: 1.1rem 1.25rem 1.3rem;
    box-shadow: 3px 8px 20px rgba(0, 0, 0, 0.45), 0 0 0 1px rgba(201, 184, 130, 0.2);
    position: relative;
    z-index: 1;
}

.mission-panel.hidden {
    display: none;
}

.mission-header {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid rgba(28, 16, 8, 0.15);
}

.mission-header-date {
    font-size: 0.65rem;
    color: #5a3e1a;
    letter-spacing: 0.06em;
    opacity: 0.65;
}

.mission-date {
    display: block;
    font-size: 0.62rem;
    color: #5a3e1a;
    letter-spacing: 0.04em;
    opacity: 0.65;
    margin-top: 0.4rem;
}

.mission-photos {
    columns: 2;
    column-gap: 2rem;
    margin-bottom: 0.5rem;
    padding: 1.2rem 0.5rem 1.5rem;
}

.mission-polaroid {
    break-inside: avoid;
    display: inline-block;
    width: 100%;
    margin-bottom: 2rem;
    position: relative;
}

.mission-polaroid img {
    width: 100%;
    height: auto;
    display: block;
    filter:  brightness(0.8);
}

.mission-polaroid .polaroid {
    padding-bottom: 72px;
    width: 100%;
    box-sizing: border-box;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.mission-polaroid .polaroid-caption {
    font-family: "Lacquer Regular";
    font-size: 1.1rem;
    height: 72px;
    color: #2a1a08;
    line-height: 1.35;
    align-items: flex-end;
    padding-bottom: 10px;
}

.mission-polaroid:hover {
    transform: rotate(0deg) translate(0, 0) scale(1.04);
    box-shadow: 4px 8px 22px rgba(0,0,0,0.32);
    z-index: 10;
}

/* ── mount decorations ── */

.mount {
    position: absolute;
    z-index: 5;
}

/* scotch tape */
.tape {
    width: 110px;
    height: 46px;
    background-color: rgba(210, 230, 255, 0.72);
    background-image:
        repeating-linear-gradient(90deg, rgba(255,255,255,0.3) 0px, rgba(255,255,255,0.3) 1px, transparent 1px, transparent 4px),
        linear-gradient(to bottom, rgba(255,255,255,0.4) 0%, rgba(200,220,255,0.1) 100%);
    border-left: 1px solid rgba(160, 200, 240, 0.6);
    border-right: 1px solid rgba(160, 200, 240, 0.6);
}

.tape--center {
    top: -25px;
    left: 50%;
    transform: translateX(-50%) rotate(-1.5deg);
}

.tape--angled {
    top: -12px;
    left: 14px;
    transform: rotate(12deg);
}

/* push pin */
.pushpin {
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    width: 17px;
    height: 17px;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.35);
    position: absolute;
    z-index: 2;
}

.pushpin::after {
    content: '';
    position: absolute;
    bottom: -16px;
    left: 50%;
    transform: translateX(-50%);
    width: 3.5px;
    height: 16px;
    background: linear-gradient(to bottom, #aaa, #555);
    border-radius: 0 0 2px 2px;
    z-index: 1;
}

.pushpin--red   { background: radial-gradient(circle at 38% 35%, #ff9090, #c81010); }
.pushpin--blue  { background: radial-gradient(circle at 38% 35%, #90b8ff, #1535cc); }
.pushpin--green { background: radial-gradient(circle at 38% 35%, #90e0a0, #0d8a35); }
.pushpin--yellow { background: radial-gradient(circle at 38% 35%, #ffe97a, #c8a000); }

/* ── notes ── */

.mission-notes {
    margin-bottom: 1.2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(28, 16, 8, 0.12);
}

.notes-rule {
    display: none;
}

.mission-text {
    font-size: 0.88rem;
    line-height: 2;
    color: #1c1008;
    margin: 0;
}

.mission-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: #5a3e1a;
    opacity: 0.7;
    margin-bottom: 0.1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
}

.mission-body :global(p) {
    font-size: 0.88rem;
    line-height: 2;
    color: #1c1008 !important;
    margin: 0 0 0.5rem;
}

.mission-body :global(h2) {
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #5a3e1a;
    margin: 1.8rem 0 0.4rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid rgba(28, 16, 8, 0.2);
    opacity: 0.85;
}

.mission-body :global(h3) {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #5a3e1a;
    margin: 1.2rem 0 0.3rem;
    opacity: 0.7;
}

.mission-empty {
    font-size: 0.78rem;
    color: #5a3e1a;
    opacity: 0.6;
    margin: 0;
}

/* ══ responsive ══ */

@media (max-width: 600px) {
    .passports-grid {
        flex-direction: column;
        gap: 2rem;
    }
    .passport {
        flex-direction: column;
    }
    .passport-divider {
        width: 100%;
        height: 1px;
        background: repeating-linear-gradient(
            to right, rgba(28,16,8,0.2) 0px, rgba(28,16,8,0.2) 4px,
            transparent 4px, transparent 8px
        );
    }
    .mission-photos {
        columns: 1;
    }
}
.mission-polaroid.is-landscape {
    width: 75%;
    margin-left: auto;
    margin-right: auto;
}
</style>

<script>
// ── report tab switching ──
const reportTabs   = document.querySelectorAll<HTMLElement>('.report-tab');
const reportPanels = document.querySelectorAll<HTMLElement>('.mission-panel');
reportTabs.forEach(tab => {
    tab.addEventListener('click', () => {
        const idx = tab.dataset.idx;
        reportTabs.forEach(t => t.classList.remove('active'));
        reportPanels.forEach(p => p.classList.add('hidden'));
        tab.classList.add('active');
        document.querySelector<HTMLElement>(`[data-panel="${idx}"]`)?.classList.remove('hidden');
    });
});

// ── landscape detection ──
document.querySelectorAll<HTMLElement>('.mission-polaroid').forEach(polaroid => {
    const img = polaroid.querySelector('img');
    if (!img) return;
    const check = () => {
        if (img.naturalHeight > img.naturalWidth) {
            polaroid.classList.add('is-landscape');
        }
    };
    if (img.complete) check();
    else img.addEventListener('load', check);
});
</script>
