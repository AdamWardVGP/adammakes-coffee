---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ViewCounter from "../../components/ViewCounter.astro";
import DiscussionPanel from "../../components/DiscussionPanel.astro";

export async function getStaticPaths() {
    const posts = await getCollection("software");
    return posts.map((entry) => ({ params: { slug: entry.slug } }));
}

const { slug } = Astro.params;
const posts = await getCollection("software");
const entry = posts.find((item) => item.slug === slug);

if (!entry) {
    throw new Error("Software post not found");
}

const { Content } = await entry.render();
---

<BaseLayout
    title={entry.data.title}
    description={entry.data.description ?? "Software post from Adam Makes Coffee."}
>
    <h1>{entry.data.title}</h1>
    <ViewCounter slug={`software:${slug}`} />
    <Content />
    <DiscussionPanel slug={`software:${slug}`} />
</BaseLayout>
