---
import "../styles/global.css";

interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const {
    title = "Adam Makes Coffee",
    description = "Recipes, projects, and updates from Adam Makes Coffee.",
    image = "/og-coffee.png",
} = Astro.props as Props;

const siteName = "Adam Makes Coffee";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();
const currentPath = Astro.url.pathname;
---

<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate" />
    <meta name="googlebot" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate" />
    <meta name="bingbot" content="noindex, nofollow, noarchive, nosnippet, noimageindex, notranslate" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="314" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
</head>
<body>
<div class="site-shell">
    <header class="retro-hero">
        <div class="hero-inner">
            <a href="/" aria-label="Go to homepage" class="hero-logo-link">
                <img
                        class="hero-logo"
                        src="/adammakescoffee.png"
                        alt="Adam Makes Coffee logo">
            </a>
            <div class="hero-copy">
                <p class="hero-kicker">adammakes</p>
                <h1>Projects, life, and chaos logs</h1>
                <p>The corner of the internet with all my random stuff</p>
            </div>
        </div>
        <nav class="tab-nav" aria-label="Main">
            <a class={currentPath === "/" ? "active" : ""} href="/">coffee</a>
            <a class={currentPath.startsWith("/recipes") ? "active" : ""} href="/recipes">food</a>
            <a class={currentPath.startsWith("/catPhotos") ? "active" : ""} href="/catPhotos">catPhotos</a>
            <a class={currentPath.startsWith("/software") ? "active" : ""} href="/software">software</a>
            <a class={currentPath.startsWith("/whois") ? "active" : ""} href="/whois">whois</a>
            <a class={currentPath.startsWith("/guestbook") ? "active" : ""} href="/guestbook">guestbook</a>
        </nav>
    </header>

    <main class="container">
        <slot />
    </main>
</div>
<canvas id="boids-canvas" aria-hidden="true"></canvas>
<div id="binary-trail" aria-hidden="true"></div>
<div id="binary-cursor" aria-hidden="true">
    <svg viewBox="0 0 48 64" xmlns="http://www.w3.org/2000/svg" role="presentation">
        <defs>
            <linearGradient id="cursor-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#74e4ff" />
                <stop offset="50%" stop-color="#6ea7ff" />
                <stop offset="100%" stop-color="#ff4bd8" />
            </linearGradient>
            <filter id="cursor-glow" x="-50%" y="-50%" width="200%" height="200%">
                <feDropShadow dx="0" dy="0" stdDeviation="2.8" flood-color="#4ac8ff" flood-opacity="0.9" />
                <feDropShadow dx="0" dy="0" stdDeviation="4" flood-color="#ff42d6" flood-opacity="0.85" />
            </filter>
        </defs>
        <path
            d="M8 4 L8 62 L19 49 L25 64 L33 61 L27 46 L37 45 Z"
            fill="#011627"
            stroke="url(#cursor-gradient)"
            stroke-width="4.1"
            stroke-linejoin="round"
            stroke-linecap="round"
            filter="url(#cursor-glow)"
        />
    </svg>
</div>
<script is:inline>
    (() => {
        const isCoarsePointer = window.matchMedia("(pointer: coarse)").matches;
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (isCoarsePointer || reduceMotion) return;

        const trail = document.getElementById("binary-trail");
        const cursor = document.getElementById("binary-cursor");
        if (!trail || !cursor) return;

        document.body.classList.add("binary-cursor-enabled");

        let lastSpawn = 0;
        let bitCount = 0;
        const maxBits = 40;
        const classes = ["cyan", "blue", "green"];

        window.addEventListener("pointermove", (event) => {
            const now = performance.now();
            if (now - lastSpawn < 28) return;
            lastSpawn = now;

            cursor.style.left = `${event.clientX}px`;
            cursor.style.top = `${event.clientY}px`;
            cursor.style.opacity = "1";

            const bit = document.createElement("span");
            bit.className = `binary-bit ${classes[Math.floor(Math.random() * classes.length)]}`;
            bit.textContent = Math.random() > 0.5 ? "1" : "0";

            const jitterX = (Math.random() - 0.5) * 14;
            const jitterY = (Math.random() - 0.5) * 14;
            bit.style.left = `${event.clientX + jitterX}px`;
            bit.style.top = `${event.clientY + jitterY}px`;

            trail.appendChild(bit);
            bitCount += 1;

            bit.addEventListener("animationend", () => {
                bit.remove();
                bitCount = Math.max(0, bitCount - 1);
            });

            if (bitCount > maxBits) {
                const first = trail.firstElementChild;
                if (first) {
                    first.remove();
                    bitCount -= 1;
                }
            }
        });

        window.addEventListener("pointerdown", () => {
            cursor.classList.add("pulse");
            setTimeout(() => cursor.classList.remove("pulse"), 120);
        });

        window.addEventListener("pointerleave", () => {
            cursor.style.opacity = "0";
        });
    })();
</script>
<script is:inline>
    (() => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        const canvas = document.getElementById("boids-canvas");
        if (!canvas) return;
        // Move to body so it sits behind site-shell (z-index 0 vs 1)
        document.body.appendChild(canvas);
        const ctx = canvas.getContext("2d");

        const NUM_BOIDS = 35;
        const MAX_SPEED = 1.3;
        const MAX_FORCE = 0.03;
        const NEIGHBOR_RADIUS = 65;
        const SEP_RADIUS = 32;
        const REPULSOR_RADIUS = 50;
        const REPULSOR_STRENGTH = 0.25;
        const WANDER_STRENGTH = 0.012;
        const COLORS = ["#7fdbca", "#82AAFF", "#c5e478"];

        const NUM_STARS = 900;
        const STAR_COLORS = [
            "#ffffff", "#ffffff", "#ffffff", "#ffffff", // mostly white
            "#b8d4ff", // cool blue-white
            "#7fdbca", // cyan hint
            "#c5e478", // green hint
        ];
        const STAR_GLYPHS = ["✦", "✧", "✶", "✴", "⋆", "+", "×", "*"];

        const NUM_ASTEROIDS = 12;
        const ASTEROID_AVOID_RADIUS = 55;
        const ASTEROID_AVOID_STRENGTH = 1.4;

        let width, height, pageRect, stars = [];

        const resize = () => {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            const shell = document.querySelector(".site-shell");
            pageRect = shell ? shell.getBoundingClientRect() : null;
        };
        window.addEventListener("resize", resize);
        window.addEventListener("scroll", () => {
            const shell = document.querySelector(".site-shell");
            pageRect = shell ? shell.getBoundingClientRect() : null;
        }, { passive: true });
        resize();

        const initStars = () => {
            stars = Array.from({ length: NUM_STARS }, () => {
                const r = 0.1 + Math.random() * 0.38;
                return {
                    x: Math.random() * width,
                    y: Math.random() * height,
                    fontSize: Math.max(3, Math.round(r * 16)),
                    alpha: 0.2 + Math.random() * 0.65,
                    color: STAR_COLORS[Math.floor(Math.random() * STAR_COLORS.length)],
                    glyph: STAR_GLYPHS[Math.floor(Math.random() * STAR_GLYPHS.length)],
                };
            });
            stars.sort((a, b) => a.fontSize - b.fontSize);
        };
        initStars();

        const boids = Array.from({ length: NUM_BOIDS }, () => ({
            x: Math.random() * width,
            y: Math.random() * height,
            vx: (Math.random() - 0.5) * MAX_SPEED * 2,
            vy: (Math.random() - 0.5) * MAX_SPEED * 2,
            color: COLORS[Math.floor(Math.random() * COLORS.length)],
            wanderAngle: Math.random() * Math.PI * 2,
        }));

        const makeVerts = (r, n) => Array.from({ length: n }, (_, i) => {
            const a = (i / n) * Math.PI * 2;
            const jitter = r * (0.65 + Math.random() * 0.5);
            return [Math.cos(a) * jitter, Math.sin(a) * jitter];
        });

        const asteroids = Array.from({ length: NUM_ASTEROIDS }, () => {
            const r = 9 + Math.random() * 11;
            return {
                x: Math.random() * width,
                y: Math.random() * height,
                vx: (Math.random() - 0.5) * 0.55,
                vy: (Math.random() - 0.5) * 0.55,
                spin: (Math.random() - 0.5) * 0.018,
                angle: Math.random() * Math.PI * 2,
                radius: r,
                verts: makeVerts(r, 7 + Math.floor(Math.random() * 3)),
            };
        });

        const clamp = (vx, vy, max) => {
            const spd = Math.hypot(vx, vy);
            return spd > max ? [vx / spd * max, vy / spd * max] : [vx, vy];
        };

        const steerToward = (boid, tx, ty) => {
            const mag = Math.hypot(tx, ty);
            if (mag === 0) return [0, 0];
            return clamp(tx / mag * MAX_SPEED - boid.vx, ty / mag * MAX_SPEED - boid.vy, MAX_FORCE);
        };

        const INSET = 120;
        const pageRepulsor = (boid) => {
            if (!pageRect) return [0, 0];
            const r = {
                left:   pageRect.left   + INSET,
                right:  pageRect.right  - INSET,
                top:    pageRect.top    + INSET,
                bottom: pageRect.bottom - INSET,
            };
            if (r.right < r.left || r.bottom < r.top) return [0, 0];
            const nx = Math.max(r.left, Math.min(boid.x, r.right));
            const ny = Math.max(r.top,  Math.min(boid.y, r.bottom));
            const dx = boid.x - nx;
            const dy = boid.y - ny;
            const d = Math.hypot(dx, dy);
            if (d === 0 || d > REPULSOR_RADIUS) return [0, 0];
            const strength = REPULSOR_STRENGTH * (1 - d / REPULSOR_RADIUS);
            return [dx / d * strength, dy / d * strength];
        };

        const tick = (boid) => {
            let sepX = 0, sepY = 0, sepN = 0;
            let aliVx = 0, aliVy = 0, aliN = 0;
            let cohX = 0, cohY = 0, cohN = 0;

            for (const other of boids) {
                if (other === boid) continue;
                const dx = boid.x - other.x;
                const dy = boid.y - other.y;
                const d = Math.hypot(dx, dy);

                if (d < SEP_RADIUS && d > 0) {
                    sepX += dx / d;
                    sepY += dy / d;
                    sepN++;
                }
                if (d < NEIGHBOR_RADIUS) {
                    aliVx += other.vx;
                    aliVy += other.vy;
                    aliN++;
                    cohX += other.x;
                    cohY += other.y;
                    cohN++;
                }
            }

            let fx = 0, fy = 0;

            if (sepN > 0) {
                const [sx, sy] = steerToward(boid, sepX / sepN, sepY / sepN);
                fx += sx * 1.6;
                fy += sy * 1.6;
            }
            if (aliN > 0) {
                const [ax, ay] = steerToward(boid, aliVx / aliN, aliVy / aliN);
                fx += ax;
                fy += ay;
            }
            if (cohN > 0) {
                const [cx, cy] = steerToward(boid, cohX / cohN - boid.x, cohY / cohN - boid.y);
                fx += cx * 0.2;
                fy += cy * 0.2;
            }

            const [rx, ry] = pageRepulsor(boid);
            fx += rx;
            fy += ry;

            for (const a of asteroids) {
                const dx = boid.x - a.x;
                const dy = boid.y - a.y;
                const d = Math.hypot(dx, dy);
                if (d < ASTEROID_AVOID_RADIUS && d > 0) {
                    const strength = ASTEROID_AVOID_STRENGTH * (1 - d / ASTEROID_AVOID_RADIUS);
                    fx += (dx / d) * strength;
                    fy += (dy / d) * strength;
                }
            }

            boid.wanderAngle += (Math.random() - 0.5) * 0.4;
            fx += Math.cos(boid.wanderAngle) * WANDER_STRENGTH;
            fy += Math.sin(boid.wanderAngle) * WANDER_STRENGTH;

            boid.vx += fx;
            boid.vy += fy;
            [boid.vx, boid.vy] = clamp(boid.vx, boid.vy, MAX_SPEED);

            boid.x += boid.vx;
            boid.y += boid.vy;

            if (boid.x < -12) boid.x = width + 12;
            if (boid.x > width + 12) boid.x = -12;
            if (boid.y < -12) boid.y = height + 12;
            if (boid.y > height + 12) boid.y = -12;
        };

        const drawBoid = (boid) => {
            const angle = Math.atan2(boid.vy, boid.vx);
            const s = 7;

            ctx.save();
            ctx.translate(boid.x, boid.y);
            ctx.rotate(angle - Math.PI / 2);

            ctx.beginPath();
            ctx.moveTo(-s * 0.55, -s * 0.45);
            ctx.lineTo(0, s * 0.55);
            ctx.lineTo(s * 0.55, -s * 0.45);
            ctx.lineJoin = "round";

            ctx.strokeStyle = boid.color;
            ctx.lineWidth = 3.5;
            ctx.globalAlpha = 0.35;
            ctx.shadowColor = boid.color;
            ctx.shadowBlur = 14;
            ctx.stroke();

            ctx.lineWidth = 1.4;
            ctx.globalAlpha = 0.9;
            ctx.shadowBlur = 0;
            ctx.stroke();

            ctx.restore();
        };

        const tickAsteroid = (a) => {
            a.angle += a.spin;
            a.x += a.vx;
            a.y += a.vy;
            if (a.x < -20) a.x = width + 20;
            if (a.x > width + 20) a.x = -20;
            if (a.y < -20) a.y = height + 20;
            if (a.y > height + 20) a.y = -20;
        };

        const drawAsteroid = (a) => {
            ctx.save();
            ctx.translate(a.x, a.y);
            ctx.rotate(a.angle);

            ctx.beginPath();
            a.verts.forEach(([x, y], i) => {
                if (i === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            });
            ctx.closePath();

            ctx.strokeStyle = "#7a8fa8";
            ctx.lineWidth = 3;
            ctx.globalAlpha = 0.25;
            ctx.shadowColor = "#7a8fa8";
            ctx.shadowBlur = 10;
            ctx.stroke();

            ctx.lineWidth = 1.2;
            ctx.globalAlpha = 0.7;
            ctx.shadowBlur = 0;
            ctx.stroke();

            ctx.restore();
        };

        const drawStars = () => {
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.shadowBlur = 0;
            let lastSize = -1;
            for (const s of stars) {
                if (s.fontSize !== lastSize) {
                    ctx.font = `${s.fontSize}px sans-serif`;
                    lastSize = s.fontSize;
                }
                ctx.globalAlpha = s.alpha;
                ctx.fillStyle = s.color;
                ctx.fillText(s.glyph, s.x, s.y);
            }
            ctx.globalAlpha = 1;
            ctx.textAlign = "start";
            ctx.textBaseline = "alphabetic";
        };

        const frame = () => {
            ctx.clearRect(0, 0, width, height);
            drawStars();
            for (const a of asteroids) {
                tickAsteroid(a);
                drawAsteroid(a);
            }
            for (const boid of boids) {
                tick(boid);
                drawBoid(boid);
            }
            requestAnimationFrame(frame);
        };

        requestAnimationFrame(frame);
    })();
</script>
</body>
</html>
